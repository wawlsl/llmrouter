<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>模型价格 - Responses Gateway</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/layui@2.9.18/dist/css/layui.css" />
    <link rel="stylesheet" href="/public/style.css" />
  </head>
  <body class="admin-layout">
    <%- include('partials/admin_nav', { activePage, stats, notice }) %>

    <section class="card">
      <h2>模型价格 (models.dev)</h2>
      <form method="get" action="/admin/pricing" class="inline-form">
        <label>当前 provider</label>
        <input name="provider" value="<%= provider || 'openai' %>" required />
        <button type="submit">切换查看</button>
      </form>
      <form method="post" action="/admin/prices/sync" class="inline-form">
        <label>provider</label>
        <input name="provider" value="<%= provider || 'openai' %>" required />
        <label>货币单位</label>
        <input name="currency" value="<%= settings.defaultCurrency %>" required />
        <button type="submit">一键同步价格</button>
      </form>

      <h3>手动新增 / 修改模型价格</h3>
      <form method="post" action="/admin/prices/upsert" class="inline-form">
        <input type="hidden" name="provider" value="<%= provider || 'openai' %>" />
        <label>模型名</label>
        <input name="modelName" placeholder="openai/gpt-5.5" required />
        <label>输入/百万</label>
        <input name="inputPerMillion" type="number" step="0.000001" min="0" placeholder="0.15" />
        <label>输出/百万</label>
        <input name="outputPerMillion" type="number" step="0.000001" min="0" placeholder="0.60" />
        <label>缓存读/百万</label>
        <input name="cacheReadPerMillion" type="number" step="0.000001" min="0" placeholder="0.03" />
        <label>缓存写/百万</label>
        <input name="cacheWritePerMillion" type="number" step="0.000001" min="0" placeholder="0.15" />
        <label>货币</label>
        <input name="currency" value="<%= settings.defaultCurrency %>" required />
        <button type="submit">保存价格</button>
      </form>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>模型</th>
              <th>输入/百万</th>
              <th>输出/百万</th>
              <th>缓存读/百万</th>
              <th>缓存写/百万</th>
              <th>货币</th>
              <th>更新时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% prices.forEach((price) => { %>
              <tr>
                <td><code><%= price.modelName %></code></td>
                <td><%= price.inputPerMillion ?? '-' %></td>
                <td><%= price.outputPerMillion ?? '-' %></td>
                <td><%= price.cacheReadPerMillion ?? '-' %></td>
                <td><%= price.cacheWritePerMillion ?? '-' %></td>
                <td><%= price.currency %></td>
                <td><%= price.updatedAt || '-' %></td>
                <td>
                  <form method="post" action="/admin/prices/delete" onsubmit="return confirm('确认删除该模型价格?');">
                    <input type="hidden" name="provider" value="<%= provider || 'openai' %>" />
                    <input type="hidden" name="modelName" value="<%= price.modelName %>" />
                    <button class="danger" type="submit">删除</button>
                  </form>
                </td>
              </tr>
            <% }) %>
            <% if (!prices.length) { %>
              <tr><td colspan="8" class="muted">暂无价格数据，请先同步或手动新增</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </body>
</html>
